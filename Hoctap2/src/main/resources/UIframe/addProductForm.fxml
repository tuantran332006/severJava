<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" fx:id="rootPane" prefWidth="1280.0" styleClass="overlay-root" stylesheets="@cssAddProduct.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllerForapp.controllerAddProduct">

            <children>
                <VBox alignment="TOP_LEFT" layoutX="430.0" layoutY="90.0" prefHeight="610.0" prefWidth="420.0" spacing="16.0" styleClass="form-card">

                    <padding>
                        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                    </padding>

                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" prefWidth="376.0">
                        <children>
                            <VBox spacing="4.0">
                                <children>
                                    <Label styleClass="form-title" text="Thêm sản phẩm" />
                                    <Label styleClass="form-subtitle" text="Nhập thông tin sản phẩm mới" />
                                </children>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                        </children>
                    </HBox>

                    <!-- Mã sản phẩm -->
                    <VBox spacing="6.0">
                        <children>
                            <Label styleClass="field-label" text="Mã sản phẩm" />
                            <TextField fx:id="txtMaSP" promptText="Ví dụ: SP001" styleClass="input-field" />
                        </children>
                    </VBox>

                    <!-- Tên sản phẩm -->
                    <VBox spacing="6.0">
                        <children>
                            <Label styleClass="field-label" text="Tên sản phẩm" />
                            <TextField fx:id="txtTenSP" promptText="Nhập tên sản phẩm" styleClass="input-field" />
                        </children>
                    </VBox>

                    <!-- Danh mục + Giá -->
                    <HBox spacing="14.0">
                        <children>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="field-label" text="Danh mục" />
                                    <ComboBox fx:id="cbDanhMuc" prefWidth="180.0" promptText="Chọn danh mục" styleClass="combo-field" />
                                </children>
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="field-label" text="Giá bán" />
                                    <TextField fx:id="txtGia" promptText="Ví dụ: 45000" styleClass="input-field" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- Số lượng + Trạng thái -->
                    <HBox spacing="14.0">
                        <children>
                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="field-label" text="Số lượng" />
                                    <TextField fx:id="txtSoLuong" promptText="Ví dụ: 100" styleClass="input-field" />
                                </children>
                            </VBox>

                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label styleClass="field-label" text="Trạng thái" />
                                    <ComboBox fx:id="cbTrangThai" prefWidth="180.0" promptText="Chọn trạng thái" styleClass="combo-field" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- Mô tả -->
                    <VBox spacing="6.0">
                        <children>
                            <Label styleClass="field-label" text="Mô tả" />
                            <TextArea fx:id="txtMoTa" prefHeight="120.0" promptText="Nhập mô tả sản phẩm" styleClass="textarea-field" wrapText="true" />
                        </children>
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <!-- Actions -->
                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                        <children>
                            <Button mnemonicParsing="false" onAction="#handleClose" styleClass="cancel-btn" text="Hủy" />

                            <Button mnemonicParsing="false" onAction="#handleSave" styleClass="save-btn" text="Lưu sản phẩm" />
                        </children>
                    </HBox>

                </VBox>
            </children>
        </AnchorPane>

