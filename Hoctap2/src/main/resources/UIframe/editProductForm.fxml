<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="598.0" prefWidth="450.0" styleClass="overlay-root" stylesheets="@cssEditProduct.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controllerForapp.controllerEditProduct">

    <VBox prefHeight="660.0" prefWidth="450.0" spacing="16" styleClass="dialog-card">
        <padding>
            <Insets bottom="28" left="28" right="28" top="28" />
        </padding>

        <Label styleClass="dialog-title" text="Chỉnh sửa sản phẩm" />
        <Label styleClass="dialog-subtitle" text="Cập nhật thông tin sản phẩm" />

        <VBox spacing="8">
            <Label styleClass="field-label" text="Mã sản phẩm" />
            <TextField fx:id="txtMaSanPham" editable="false" prefHeight="38.0" prefWidth="394.0" promptText="Ví dụ: SP001" styleClass="input-field" />
        </VBox>

        <VBox spacing="8">
            <Label styleClass="field-label" text="Tên sản phẩm" />
            <TextField fx:id="txtTenSanPham" prefHeight="44.0" prefWidth="394.0" promptText="Nhập tên sản phẩm" styleClass="input-field" />
        </VBox>

        <HBox spacing="16">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Danh mục" />
                <ComboBox fx:id="cbDanhMuc" maxWidth="1.7976931348623157E308" promptText="Chọn danh mục" styleClass="input-field" />
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Giá bán" />
                <TextField fx:id="txtGiaBan" promptText="Ví dụ: 45000" styleClass="input-field" />
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Số lượng" />
                <TextField fx:id="txtSoLuong" promptText="Ví dụ: 100" styleClass="input-field" />
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label styleClass="field-label" text="Trạng thái" />
                <ComboBox fx:id="cbTrangThai" maxWidth="1.7976931348623157E308" promptText="Chọn trạng thái" styleClass="input-field" />
            </VBox>
        </HBox>

        <VBox spacing="8">
            <Label styleClass="field-label" text="Mô tả" />
            <TextArea fx:id="txtMoTa" prefHeight="65.0" prefRowCount="4" prefWidth="442.0" promptText="Nhập mô tả sản phẩm" styleClass="text-area-custom" wrapText="true" />
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="14">
            <Button fx:id="btnHuy" onAction="#handleCancel" styleClass="btn-cancel" text="Hủy" />
            <Button fx:id="btnLuu" onAction="#handleSave" styleClass="btn-save" text="Lưu thay đổi" />
        </HBox>
    </VBox>
</StackPane>
